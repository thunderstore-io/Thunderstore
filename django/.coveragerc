[run]
branch = True
data_file = coverage.coverage
# relative_files: stable thunderstore/... paths in coverage.xml across Docker vs host.
# Cobertura may still use <source>/app</source>; run patch_coverage_xml_for_gutters.py
# after `coverage xml` (or chain it in the same docker compose exec) for Coverage Gutters.
relative_files = True
omit =
    *migrations/*
    *settings*
    *tests/*
    */apps.py
    */urls.py
    */wsgi.py
    */manage.py
    */admin.py
    thunderstore/debug/*
    */python-packages/*

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:


[html]
directory = htmlcov
